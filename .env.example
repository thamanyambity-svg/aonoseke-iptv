# IPTV Web Player Environment Variables
# Copy this file to .env.local and update values as needed

# Playlist Configuration
# URL to the playlist JSON file (can be local or remote)
# Default: /playlist.json
VITE_PLAYLIST_URL=https://your-server.com/playlist.json

# Maximum number of channels to display
# Default: 2000
VITE_MAX_CHANNELS=2000

# API timeout in milliseconds
# Default: 10000
VITE_API_TIMEOUT=10000

# Enable logging to console
# Default: true
VITE_ENABLE_LOGGING=true

# Enable analytics tracking (for future integrations)
# Default: false
VITE_ENABLE_ANALYTICS=false

# ──────────────────────────────────────────────
# Supabase (backend : comptes + analytics annonceurs)
# Sans ces variables, l'app fonctionne en mode démo (localStorage).
# 1. Crée un projet sur https://supabase.com
# 2. Exécute supabase/schema.sql dans le SQL Editor
# 3. Settings → API → copie l'URL et la clé "anon public"
# 4. (OAuth) Authentication → Providers → active Google / Facebook
# ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ──────────────────────────────────────────────
# Flutterwave (abonnement premium — Mobile Money RDC + carte)
# Couvre M-Pesa, Orange Money, Airtel Money. Sans clé → mode démo.
# Dashboard Flutterwave → Settings → API → clé publique.
# ⚠️ La confirmation de paiement doit être vérifiée côté serveur
#    (webhook Flutterwave → Supabase) avant d'accorder le premium.
# ──────────────────────────────────────────────
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxx-X
